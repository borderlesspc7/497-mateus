rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function hasRole(roles) {
      return isSignedIn() && userData().role in roles;
    }

    function isGerenteOrAdmin() {
      return hasRole(['admin', 'gerente']);
    }

    function isAdmin() {
      return hasRole(['admin']);
    }

    match /usuarios/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false;
    }

    match /logs_auditoria/{docId} {
      allow read: if isGerenteOrAdmin();
      allow write: if false;
    }

    match /extratos/{docId} {
      allow read, write: if isGerenteOrAdmin();
    }

    match /administradoras/{docId} {
      allow read: if isSignedIn();
      allow write: if isGerenteOrAdmin();
    }

    match /planos/{docId} {
      allow read: if isSignedIn();
      allow write: if isGerenteOrAdmin();
    }

    match /vendas/{docId} {
      allow read, write: if isSignedIn();

      match /historico/{historicoId} {
        allow read, write: if isSignedIn();
      }

      match /historico_atendimento/{historicoId} {
        allow read, write: if isSignedIn();
      }
    }

    match /consorciados/{docId} {
      allow read, write: if isSignedIn();
    }

    match /equipes/{docId} {
      allow read: if isSignedIn();
      allow write: if isGerenteOrAdmin();
    }

    match /vendedores/{docId} {
      allow read: if isSignedIn();
      allow write: if isGerenteOrAdmin();
    }

    match /metas/{metaId} {
      allow read: if isSignedIn();
      allow write: if isGerenteOrAdmin();
    }

    match /realizacoes/{realizacaoId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /conquistas/{conquistaId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
